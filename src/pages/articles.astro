---
import Layout from "../layouts/Layout.astro";
---

<Layout page="articles" title="" description="">
	<main class="wrapper">
		<div class="hero"><h1>Articles by Greg Harmeling, Psy.D., LMFT</h1></div>

		<section class="article-grid">
			<article>
				<img src="/src/images/thumb-post1.jpg" alt="" class="post-thumb" />
				<div class="post-blurb">
					<h2>
						How Narcissistic Abuse Rewires a Man's Sexuality — and How to Heal
					</h2>
					<p>
						Narcissistic abuse doesn't just damage your sense of self; it
						rewires how you experience sexuality and intimacy.<br /><a
							href="./posts/post-1"
						>
							Read more....
						</a>
					</p>
				</div>
			</article>
			<article>
				<img src="/src/images/thumb-post2.jpg" alt="" class="post-thumb" />
				<div class="post-blurb">
					<h2>
						Why Men Lose Sexual Confidence After a Toxic Relationship — and How
						to Get It Back
					</h2>
					<p>
						Toxic relationships don't just hurt your heart — they damage your
						sexual confidence in ways nobody warns you about.
						<br /><a href="./posts/post-2">Read more....</a>
					</p>
				</div>
			</article>
		</section>
	</main></Layout
>
<style lang="scss">
	.hero {
		background: url(../images/velewe-nature-reserve-nl.jpg);
		background-size: cover;
		background-position: center center;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100vw;
		height: 600px;
		@media (max-width: 1023px) {
			height: 300px;
		}
		h1 {
			font-size: xx-large;
			text-align: center;

			@media (min-width: 1024px) {
				font-size: xxx-large;
			}
		}
	}
	.article-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 3rem;
		padding: 2rem;
		max-width: 1200px;
		margin: 0 auto 5rem;

		article {
			background: #8d89b7;
			border: 1px solid #bab7d5;
			border-radius: 8px;
			overflow: hidden;
			display: flex;
			flex-direction: column;

			.post-thumb {
			}

			.post-blurb {
				color: #000;
				padding: 1rem;

				h2 {
					font-size: 1.5rem;
					line-height: 1.25;
					padding: 0;
				}
			}
		}
	}
</style>
